{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "declaration": true,
    "emitDeclarationOnly": true,
    "declarationDir": "dist/types",
    "noEmit": false,
    "rootDir": "src",
    "allowImportingTsExtensions": true
  },
  "include": [
    "src/vite-env.d.ts",
    "src/design-system/**/*.ts",
    "src/design-system/**/*.tsx",
    "src/lib/**/*.ts"
  ]
}
