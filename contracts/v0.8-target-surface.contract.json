{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "name": "v0.8-target-surface",
  "version": "0.8.0-alpha.0",
  "status": "target-source-of-truth",
  "purpose": "Define the v0.8 Make-facing target surface before regenerating the design system code.",
  "strategy": [
    "target-surface-first",
    "guidelines-and-contracts-second",
    "code-regeneration-third",
    "legacy-deletion-last"
  ],
  "scope": {
    "makeFacing": [
      "guidelines/runtime",
      "guidelines/reference",
      "guidelines/examples/golden",
      "guidelines/prompts",
      "contracts",
      "benchmarks/figma-make/cases",
      "benchmarks/figma-make/scoring"
    ],
    "codeToRegenerateAfterReset": [
      "src/design-system/components",
      "src/design-system/composition",
      "src/design-system/decision",
      "src/design-system/forms",
      "src/design-system/patterns",
      "src/design-system/stories",
      "src/design-system/index.ts"
    ]
  },
  "canonicalTokenFile": "src/design-system/foundations/tokens.css",
  "doNotCreate": [
    "src/design-system/tokens.css"
  ],
  "targetPublicSurface": {
    "foundations": [
      "tokens",
      "styles",
      "visual-rules"
    ],
    "coreComponents": [
      "Button",
      "Card",
      "Table",
      "Tabs",
      "Divider",
      "Dialog",
      "Popover",
      "Tooltip",
      "Forms"
    ],
    "semanticDisplay": [
      "SemanticTag",
      "SemanticPill",
      "StatusIndicator",
      "MetaLabel"
    ],
    "composition": [
      "WorkspaceShell",
      "MainNavigation",
      "PageHeading",
      "FilterBar",
      "MasterDetailLayout",
      "WorkspaceDetailPanel",
      "SidePanel",
      "SectionStack",
      "SectionBlock",
      "ListContainer",
      "StickyActionBar"
    ],
    "decision": [
      "MetricBlock",
      "DecisionBlock",
      "EvidenceBlock",
      "ActionBlock",
      "StatusSummary",
      "ReviewQueueRow",
      "ActionRow",
      "EvidenceRow"
    ],
    "screenPatterns": [
      "InstalledBase",
      "CustomerMonitoring"
    ]
  },
  "deprecatedPublicSurface": [
    "HealthPill",
    "CoverageTag",
    "DppTag",
    "ConnectivityLabel",
    "StatusWithIcon",
    "PriorityPill",
    "PriorityLabel",
    "ProofStatus",
    "SourceStrengthPill",
    "StatusPill",
    "MetricCard",
    "AlertCard",
    "RecommendationCard",
    "ActionCard",
    "EvidenceCard",
    "InsightCard",
    "RiskCard",
    "CustomerCard",
    "AssetCard"
  ],
  "allowedTemporaryLegacyCode": {
    "rule": "Legacy files may temporarily exist only as internal migration helpers until regeneration and deletion.",
    "mustNotBe": [
      "preferred",
      "approved-for-new-generation",
      "recommended-by-runtime-guidelines",
      "used-by-golden-examples",
      "used-by-benchmarks-as-positive-examples"
    ]
  },
  "targetRules": [
    "same-visual-structure-same-component",
    "business-role-differences-through-props-and-contracts",
    "no-public-component-without-distinct-structure-or-responsibility",
    "no-local-components-in-generated-screens",
    "prototype-visual-system-applies-to-whole-ds",
    "installed-base-is-strict-contractual-screen",
    "customer-monitoring-is-second-generation-proof",
    "legacy-is-deleted-after-target-regeneration"
  ],
  "positiveGenerationProofs": [
    "Installed Base Intelligence",
    "Customer Monitoring"
  ]
}
