{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "name": "tokens",
  "version": "0.8.0-alpha.0",
  "status": "active-runtime-contract",
  "purpose": "Lock the v0.8 prototype-derived visual token system for all Make-facing components and examples.",
  "canonicalTokenFile": "src/design-system/foundations/tokens.css",
  "publicStyleEntry": "src/design-system/styles.css",
  "namespace": "--ec-*",
  "doNotCreate": [
    "src/design-system/tokens.css",
    "local-token-namespace",
    "local-root-theme",
    "parallel-brand-tokens",
    "component-specific-color-scale",
    "component-specific-radius-scale",
    "component-specific-shadow-scale"
  ],
  "prototypeDerivedRules": {
    "brandReferences": "anonymized",
    "visualGrammar": "preserved",
    "surface": "white-first",
    "border": "rgba(0, 0, 0, 0.1)",
    "radius": "0.625rem",
    "inputBackground": "#f3f3f5",
    "bodyBackground": "#ffffff",
    "bodyText": "#030213",
    "mutedText": "#717182",
    "accentGreen": "#00985f",
    "accentGreenHover": "#007a4a"
  },
  "requiredTokenGroups": [
    "color-background",
    "color-surface",
    "color-text",
    "color-border",
    "color-input",
    "color-primary",
    "color-status",
    "font-family",
    "font-size",
    "line-height",
    "font-weight",
    "radius",
    "spacing",
    "density",
    "shadow",
    "transition"
  ],
  "requiredTokens": [
    "--ec-color-background",
    "--ec-color-surface",
    "--ec-color-surface-muted",
    "--ec-color-text-primary",
    "--ec-color-text-secondary",
    "--ec-color-text-muted",
    "--ec-color-border",
    "--ec-color-input-background",
    "--ec-color-primary",
    "--ec-color-primary-hover",
    "--ec-color-primary-soft",
    "--ec-color-primary-border",
    "--ec-radius-md",
    "--ec-spacing-sm",
    "--ec-spacing-md",
    "--ec-density-nav-height",
    "--ec-density-filter-bar-height",
    "--ec-density-row-height-md",
    "--ec-density-panel-width-md",
    "--ec-shadow-card",
    "--ec-shadow-panel"
  ],
  "shadcnCompatibilityAliases": [
    "--background",
    "--foreground",
    "--card",
    "--card-foreground",
    "--popover",
    "--popover-foreground",
    "--primary",
    "--primary-foreground",
    "--secondary",
    "--secondary-foreground",
    "--muted",
    "--muted-foreground",
    "--accent",
    "--accent-foreground",
    "--destructive",
    "--destructive-foreground",
    "--border",
    "--input",
    "--input-background",
    "--ring",
    "--radius"
  ],
  "componentCoverageRequirement": "All active DS components and active golden examples must use this token grammar. The extraction is not limited to Installed Base.",
  "visualSystemExitCriteria": [
    "tokens-use-ec-namespace",
    "prototype-brand-references-anonymized",
    "prototype-visual-grammar-preserved",
    "white-first-surfaces",
    "compact-density",
    "borders-before-shadows",
    "neutral-input-background",
    "single-radius-scale",
    "single-spacing-scale",
    "single-status-color-scale",
    "shadcn-compatible-aliases-exposed"
  ]
}
