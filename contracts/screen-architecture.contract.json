{
  "$schema": "./schema/generation-contract.schema.json",
  "name": "screen-architecture",
  "version": "0.5.0",
  "sourceGuidelines": [
    "guidelines/setup.md",
    "guidelines/Guidelines.md",
    "guidelines/review/workspace-v2-checklist.md",
    "guidelines/review/blocking-checklist.md"
  ],
  "decisionWorkspace": {
    "requiredWhen": [
      "review",
      "comparison",
      "list-detail",
      "evidence-review",
      "follow-through",
      "customer-monitoring",
      "installed-base-exploration",
      "asset-recommendation-review",
      "renewal-risk-review",
      "qbr-readiness"
    ],
    "recommendedHierarchy": [
      "WorkspaceShell",
      "PageHeading",
      "FilterBar",
      "MasterDetailLayout",
      "ListContainer",
      "WorkspaceDetailPanel",
      "Tabs",
      "StickyActionBar"
    ],
    "allowedAlternatives": {
      "FilterBar": ["SecondaryNavigation"],
      "StickyActionBar": ["ActionRow"],
      "Tabs": ["HeaderTabs", "SegmentedControl"]
    },
    "recommendedDetailContent": [
      "SectionStack",
      "SectionBlock",
      "KeyValueList",
      "EvidenceRow",
      "RecommendationReviewPanel",
      "RecommendationCard",
      "AlertCard",
      "ValueProofCard",
      "AssetIntelligenceSummary",
      "ActionRow"
    ],
    "forbiddenPatterns": [
      "long-card-stack",
      "generic-dashboard",
      "equal-card-grid-for-repeated-facts",
      "one-card-per-fact",
      "one-card-per-action",
      "custom-drawer",
      "custom-tabs",
      "custom-side-panel"
    ],
    "rowFirstRules": {
      "repeatedCustomers": "CustomerQueueRow",
      "repeatedAssets": "AssetQueueRow",
      "repeatedRisks": "RiskQueueRow",
      "repeatedRecommendations": "RecommendationQueueRow",
      "repeatedReviewItems": "ReviewQueueRow",
      "repeatedEvidence": "EvidenceRow",
      "repeatedActions": "ActionRow"
    }
  },
  "minimumScreenIntent": {
    "requiresOneClearDecision": true,
    "requiresFactsBeforeInterpretation": true,
    "requiresFollowThroughForActionableScreens": true
  }
}
