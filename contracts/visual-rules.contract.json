{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "name": "visual-rules",
  "version": "0.6.0",
  "status": "active-runtime-contract",
  "purpose": "Prevent GenAI visual drift in generated screens by turning visual rules into testable blockers.",
  "sourceGuidelines": [
    "guidelines/runtime/visual-rules.md",
    "guidelines/styles.md",
    "guidelines/tokens.md",
    "guidelines/source/visual-brand/visual-brand-v0.4.md"
  ],
  "coreDirection": [
    "white-first",
    "sober",
    "structured",
    "B2B",
    "operational",
    "trust-aware",
    "action-oriented"
  ],
  "requiredRuntimeRules": [
    "white-first",
    "borders-before-shadows",
    "package-components-create-hierarchy",
    "green-only-with-meaning",
    "status-not-color-only",
    "evidence-strength-not-overstated",
    "uncertainty-remains-readable",
    "no-local-visual-system"
  ],
  "forbiddenVisualPatterns": [
    "glassmorphism",
    "gradient-heavy-layout",
    "shadow-heavy-card",
    "glow-effects",
    "card-saturated-layout",
    "custom-local-brand-panel",
    "custom-visual-system",
    "custom-button-system",
    "custom-badge-system",
    "custom-tab-system",
    "custom-row-system",
    "colored-cards-for-every-status",
    "green-used-as-decoration",
    "visual-emphasis-overstates-weak-evidence",
    "local-visual-system"
  ],
  "forbiddenLocalWrapperNames": [
    "PremiumCard",
    "BrandPanel",
    "GlassSurface",
    "StatusChip",
    "CustomTabs",
    "MetricTile",
    "LocalCard",
    "GradientPanel",
    "HeroCard",
    "BrandHero",
    "GlassCard"
  ],
  "forbiddenGeneratedTextClaims": [
    "use glassmorphism",
    "add glassmorphism",
    "use decorative gradients",
    "add decorative gradients",
    "make every card colorful",
    "use green as decoration",
    "make weak evidence look validated",
    "hide uncertainty visually",
    "create a local visual system",
    "create custom brand panels"
  ],
  "forbiddenGeneratedCodePatterns": [
    "backdrop-blur",
    "blur-xl",
    "bg-gradient-to-",
    "from-emerald",
    "from-green",
    "via-emerald",
    "via-green",
    "drop-shadow-2xl",
    "shadow-2xl",
    "shadow-xl",
    "ring-green-400/50",
    "text-shadow",
    "filter: blur",
    "backdrop-filter",
    "linear-gradient",
    "radial-gradient"
  ],
  "colorRules": {
    "primaryGreen": {
      "allowedUses": [
        "primary-actions",
        "selected-states",
        "active-navigation",
        "positive-status-when-appropriate",
        "validated-information-when-evidence-supports-it"
      ],
      "forbiddenUses": [
        "decoration",
        "making-weak-evidence-look-stronger",
        "implying-certainty-with-partial-evidence"
      ]
    },
    "statusColor": {
      "requiredCompanionSignals": [
        "label",
        "text",
        "icon-or-shape-when-useful",
        "source-or-validation-context-when-trust-matters"
      ],
      "forbiddenUses": [
        "color-only-status",
        "color-only-priority",
        "color-only-evidence-strength"
      ]
    }
  },
  "trustVisibilityRules": [
    "source-scope-readable-when-relevant",
    "source-strength-readable-when-relevant",
    "freshness-readable-when-relevant",
    "validation-status-readable-when-relevant",
    "proof-readiness-readable-when-relevant",
    "human-validation-readable-when-relevant"
  ],
  "informationDensityRules": [
    "do-not-make-every-fact-signal-proof-point-and-action-visually-equal",
    "show-decision-critical-summary-first",
    "move-supporting-evidence-to-secondary-level-when-possible"
  ],
  "filesToScanForGeneratedVisualDrift": [
    "guidelines/examples/golden",
    "benchmarks/figma-make/outputs"
  ],
  "repairIfDetected": [
    "visual-treatment-overstates-evidence-strength",
    "expected-outcome-styled-as-proven-value",
    "internal-proof-styled-as-customer-ready-without-validation",
    "uncertainty-hidden-through-low-contrast-or-visual-treatment",
    "local-visual-system-created",
    "decorative-gradient-or-glass-treatment-created",
    "green-used-as-decoration"
  ]
}
