{
  "$schema": "./schema/generation-contract.schema.json",
  "name": "package",
  "version": "0.7.0-alpha.0",
  "sourceGuidelines": [
    "guidelines/Guidelines.md",
    "guidelines/setup.md",
    "guidelines/evaluation/review/blocking-checklist.md",
    "guidelines/reference/screen-contracts/installed-base-intelligence.md"
  ],
  "packageName": "design-system-ai-lab",
  "requiredStyleImport": "design-system-ai-lab/styles.css",
  "allowedImports": [
    "design-system-ai-lab"
  ],
  "forbiddenImports": [
    "design-system-ai-lab/dist",
    "design-system-ai-lab/src",
    "./components/ui",
    "packages/design-system-ai-lab",
    "src/design-system",
    "src/components/ui",
    "components/ui"
  ],
  "forbiddenLocalFolders": [
    "packages/design-system-ai-lab",
    "src/design-system",
    "src/components/ui",
    "components/ui"
  ],
  "requiredAppFile": "App.tsx",
  "requiredExport": "default",
  "release": {
    "tag": "next",
    "version": "0.7.0-alpha.0",
    "publishCommand": "npm publish --tag next"
  },
  "notes": [
    "Generated screens must use the public package root only.",
    "Generated screens must import the public stylesheet once.",
    "Generated screens must not recreate a local design system.",
    "Installed Base Intelligence screen generation must preserve the public v0.7-alpha screen-level package surface."
  ]
}
