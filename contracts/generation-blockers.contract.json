{
  "$schema": "./schema/generation-contract.schema.json",
  "name": "generation-blockers",
  "version": "0.5.0",
  "sourceGuidelines": [
    "guidelines/evaluation/review/blocking-checklist.md",
    "guidelines/evaluation/review/anti-patterns.md",
    "guidelines/evaluation/review/repair-routing.md",
    "guidelines/setup.md"
  ],
  "blockingFailures": [
    {
      "id": "missing-visible-app",
      "category": "app-shell",
      "description": "App.tsx does not render a complete visible screen."
    },
    {
      "id": "missing-package-root-import",
      "category": "package-contract",
      "description": "Components are not imported from design-system-ai-lab."
    },
    {
      "id": "missing-stylesheet-import",
      "category": "package-contract",
      "description": "design-system-ai-lab/styles.css is not imported."
    },
    {
      "id": "internal-package-import",
      "category": "package-contract",
      "description": "Internal package paths are imported."
    },
    {
      "id": "local-design-system-recreation",
      "category": "package-contract",
      "description": "The generation creates local design system folders or components."
    },
    {
      "id": "raw-form-controls",
      "category": "component-contract",
      "description": "Raw form controls replace package form components."
    },
    {
      "id": "ignored-business-patterns",
      "category": "business-patterns",
      "description": "Available business patterns are ignored when the intent matches."
    },
    {
      "id": "missing-workspace-structure",
      "category": "screen-architecture",
      "description": "Workspace structure is missing when the task requires list/detail review."
    },
    {
      "id": "missing-detail-panel",
      "category": "screen-architecture",
      "description": "A list/detail task has no selected item detail panel."
    },
    {
      "id": "missing-list-container",
      "category": "screen-architecture",
      "description": "Queue rows are not grouped in ListContainer."
    },
    {
      "id": "card-stack-drift",
      "category": "screen-architecture",
      "description": "The output is a long stack of equal generic cards."
    },
    {
      "id": "alert-without-recommendation",
      "category": "actionability",
      "description": "An AlertCard has no recommendation."
    },
    {
      "id": "action-without-ownership",
      "category": "actionability",
      "description": "An ActionCard or ActionRow has no owner, due date or priority."
    },
    {
      "id": "invented-evidence",
      "category": "evidence-and-trust",
      "description": "Source, evidence, asset facts or value proof are unsupported or invented."
    },
    {
      "id": "expected-as-proven",
      "category": "evidence-and-trust",
      "description": "Expected outcomes are presented as proven value."
    },
    {
      "id": "ai-confidence-as-source-strength",
      "category": "evidence-and-trust",
      "description": "AI confidence is presented as source strength or validation."
    },
    {
      "id": "partial-visibility-overstated",
      "category": "evidence-and-trust",
      "description": "Partial source visibility is presented as complete asset knowledge."
    },
    {
      "id": "hidden-human-validation",
      "category": "evidence-and-trust",
      "description": "Human validation is hidden for a critical decision."
    }
  ],
  "defaultDecision": "reject-before-quality-review",
  "repairRouting": {
    "missing-visible-app": "guidelines/evaluation/review/blocking-checklist.md",
    "missing-package-root-import": "guidelines/evaluation/repair/invalid-props-or-local-visual-components.md",
    "missing-stylesheet-import": "guidelines/evaluation/repair/invalid-props-or-local-visual-components.md",
    "internal-package-import": "guidelines/evaluation/repair/invalid-props-or-local-visual-components.md",
    "local-design-system-recreation": "guidelines/evaluation/repair/invalid-props-or-local-visual-components.md",
    "raw-form-controls": "guidelines/evaluation/repair/invalid-props-or-local-visual-components.md",
    "ignored-business-patterns": "guidelines/evaluation/repair/weak-layout.md",
    "missing-workspace-structure": "guidelines/evaluation/repair/weak-layout.md",
    "missing-detail-panel": "guidelines/evaluation/repair/missing-detail-panel.md",
    "missing-list-container": "guidelines/evaluation/repair/missing-list-container.md",
    "card-stack-drift": "guidelines/evaluation/repair/card-saturation.md",
    "alert-without-recommendation": "guidelines/evaluation/repair/actions-without-ownership.md",
    "action-without-ownership": "guidelines/evaluation/repair/actions-without-ownership.md",
    "invented-evidence": "guidelines/evaluation/repair/invented-evidence.md",
    "expected-as-proven": "guidelines/evaluation/repair/expected-outcomes-as-proven-value.md",
    "ai-confidence-as-source-strength": "guidelines/evaluation/repair/ai-confidence-as-source-strength.md",
    "partial-visibility-overstated": "guidelines/evaluation/repair/partial-visibility-overstated.md",
    "hidden-human-validation": "guidelines/evaluation/repair/missing-human-validation.md"
  }
}
