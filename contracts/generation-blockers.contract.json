{
  "$schema": "./schema/generation-contract.schema.json",
  "name": "generation-blockers",
  "version": "0.5.0",
  "sourceGuidelines": [
    "guidelines/review/blocking-checklist.md",
    "guidelines/review/anti-patterns.md",
    "guidelines/setup.md"
  ],
  "blockingFailures": [
    {
      "id": "missing-visible-app",
      "category": "app-shell",
      "description": "App.tsx does not render a complete visible screen."
    },
    {
      "id": "missing-package-root-import",
      "category": "package-contract",
      "description": "Components are not imported from design-system-ai-lab."
    },
    {
      "id": "missing-stylesheet-import",
      "category": "package-contract",
      "description": "design-system-ai-lab/styles.css is not imported."
    },
    {
      "id": "internal-package-import",
      "category": "package-contract",
      "description": "Internal package paths are imported."
    },
    {
      "id": "local-design-system-recreation",
      "category": "package-contract",
      "description": "The generation creates local design system folders or components."
    },
    {
      "id": "raw-form-controls",
      "category": "component-contract",
      "description": "Raw form controls replace package form components."
    },
    {
      "id": "ignored-business-patterns",
      "category": "business-patterns",
      "description": "Available business patterns are ignored when the intent matches."
    },
    {
      "id": "missing-workspace-structure",
      "category": "screen-architecture",
      "description": "Workspace structure is missing when the task requires list/detail review."
    },
    {
      "id": "card-stack-drift",
      "category": "screen-architecture",
      "description": "The output is a long stack of equal generic cards."
    },
    {
      "id": "alert-without-recommendation",
      "category": "actionability",
      "description": "An AlertCard has no recommendation."
    },
    {
      "id": "action-without-ownership",
      "category": "actionability",
      "description": "An ActionCard or ActionRow has no owner, due date or priority."
    },
    {
      "id": "invented-evidence",
      "category": "evidence-and-trust",
      "description": "Source, evidence, asset facts or value proof are invented."
    },
    {
      "id": "expected-as-proven",
      "category": "evidence-and-trust",
      "description": "Expected outcomes are presented as proven value."
    },
    {
      "id": "hidden-human-validation",
      "category": "evidence-and-trust",
      "description": "Human validation is hidden for a critical decision."
    }
  ],
  "defaultDecision": "reject-before-quality-review",
  "repairRouting": {
    "card-stack-drift": "guidelines/repair-prompts/card-saturation.md",
    "missing-workspace-structure": "guidelines/repair-prompts/weak-layout.md",
    "missing-visible-app": "guidelines/review/blocking-checklist.md",
    "local-design-system-recreation": "guidelines/review/anti-patterns.md",
    "invented-evidence": "guidelines/review/anti-patterns.md",
    "expected-as-proven": "guidelines/review/anti-patterns.md",
    "action-without-ownership": "guidelines/review/anti-patterns.md"
  }
}
