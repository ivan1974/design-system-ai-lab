{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "installed-base-domain.contract.schema.json",
  "title": "Installed Base Domain Contract",
  "type": "object",
  "required": [
    "name",
    "version",
    "status",
    "source",
    "screenContext",
    "assetHierarchy",
    "assetFamilies",
    "assetStates",
    "connectivityValues",
    "filterConnectivityValues",
    "healthValues",
    "coverageValues",
    "dppValues",
    "filterDppValues",
    "statusLabels",
    "filterStatusValues",
    "statusIcons",
    "ageValues",
    "thirdPartyAssetRules",
    "attentionRequiredRule",
    "factInterpretationSeparation",
    "progressiveDecisionDisclosure"
  ],
  "properties": {
    "$schema": { "type": "string" },
    "name": { "const": "installed-base-domain" },
    "version": { "type": "string" },
    "status": { "type": "string" },
    "source": { "type": "string" },
    "screenContext": { "const": "installed-base-intelligence" },
    "assetHierarchy": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 4,
      "maxItems": 4
    },
    "assetFamilies": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 8,
      "maxItems": 8
    },
    "assetStates": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 6,
      "maxItems": 6
    },
    "connectivityValues": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 3,
      "maxItems": 3
    },
    "filterConnectivityValues": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 2,
      "maxItems": 2
    },
    "healthValues": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 6,
      "maxItems": 6
    },
    "coverageValues": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 4,
      "maxItems": 4
    },
    "dppValues": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 2,
      "maxItems": 2
    },
    "filterDppValues": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 2,
      "maxItems": 2
    },
    "statusLabels": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 5,
      "maxItems": 5
    },
    "filterStatusValues": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 4,
      "maxItems": 4
    },
    "statusIcons": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "ageValues": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 3,
      "maxItems": 3
    },
    "thirdPartyAssetRules": {
      "type": "object",
      "required": ["connectivity", "coverage", "health", "status", "exceptionsAllowed"],
      "properties": {
        "connectivity": { "const": "Unknown" },
        "coverage": { "const": "No Coverage" },
        "health": { "const": "Unknown" },
        "status": { "const": "No record" },
        "exceptionsAllowed": { "const": false }
      },
      "additionalProperties": false
    },
    "attentionRequiredRule": { "type": "object" },
    "factInterpretationSeparation": { "type": "object" },
    "progressiveDecisionDisclosure": { "type": "object" }
  },
  "additionalProperties": true
}
