{
  "extends": "./tsconfig.app.json",
  "compilerOptions": {
    "declaration": true,
    "emitDeclarationOnly": true,
    "declarationDir": "dist",
    "rootDir": "src/design-system",
    "noEmit": false,
    "allowImportingTsExtensions": false
  },
  "include": [
    "src/design-system/**/*"
  ],
  "exclude": [
    "src/design-system/style-entry.ts",
    "src/design-system/stories",
    "src/design-system/**/*.stories.tsx",
    "src/design-system/**/*.mdx"
  ]
}