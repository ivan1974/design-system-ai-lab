{
  "name": "design-system-ai-lab",
  "private": false,
  "version": "0.8.1",
  "type": "module",
  "main": "./dist/design-system/public-api.js",
  "module": "./dist/design-system/public-api.js",
  "types": "./dist/types/design-system/public-api.d.ts",
  "style": "./dist/styles.css",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/types/design-system/public-api.d.ts",
      "import": "./dist/design-system/public-api.js"
    },
    "./styles.css": "./dist/styles.css",
    "./design-system/primitives": {
      "types": "./dist/types/design-system/primitives/index.d.ts",
      "import": "./dist/design-system/primitives/index.js"
    },
    "./design-system/components": {
      "types": "./dist/types/design-system/components/index.d.ts",
      "import": "./dist/design-system/components/index.js"
    },
    "./dist/*": "./dist/*"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "build": "vite build && npm run build:types",
    "build:types": "tsc -p tsconfig.build.json",
    "dev": "vite",
    "playground": "vite --config apps/playground/vite.config.ts --host 0.0.0.0",
    "validate:run": "node scripts/validate-run.mjs",
    "ai:brief": "node scripts/ai-cli.mjs brief",
    "ai:explore": "node scripts/ai-cli.mjs explore",
    "ai:validate": "node scripts/ai-cli.mjs validate",
    "ai:report": "node scripts/ai-report.mjs",
    "ai:playground:add": "node scripts/ai-playground-add.mjs"
  },
  "peerDependencies": {
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "dependencies": {
    "@emotion/react": "11.14.0",
    "@emotion/styled": "11.14.1",
    "@mui/icons-material": "7.3.5",
    "@mui/material": "7.3.5",
    "@popperjs/core": "2.11.8",
    "@radix-ui/react-accordion": "1.2.3",
    "@radix-ui/react-alert-dialog": "1.1.6",
    "@radix-ui/react-aspect-ratio": "1.1.2",
    "@radix-ui/react-avatar": "1.1.3",
    "@radix-ui/react-checkbox": "1.1.4",
    "@radix-ui/react-collapsible": "1.1.3",
    "@radix-ui/react-context-menu": "2.2.6",
    "@radix-ui/react-dialog": "1.1.6",
    "@radix-ui/react-dropdown-menu": "2.1.6",
    "@radix-ui/react-hover-card": "1.1.6",
    "@radix-ui/react-label": "2.1.2",
    "@radix-ui/react-menubar": "1.1.6",
    "@radix-ui/react-navigation-menu": "1.2.5",
    "@radix-ui/react-popover": "1.1.6",
    "@radix-ui/react-progress": "1.1.2",
    "@radix-ui/react-radio-group": "1.2.3",
    "@radix-ui/react-scroll-area": "1.2.3",
    "@radix-ui/react-select": "2.1.6",
    "@radix-ui/react-separator": "1.1.2",
    "@radix-ui/react-slider": "1.2.3",
    "@radix-ui/react-slot": "1.1.2",
    "@radix-ui/react-switch": "1.1.3",
    "@radix-ui/react-tabs": "1.1.3",
    "@radix-ui/react-toggle": "1.1.2",
    "@radix-ui/react-toggle-group": "1.1.2",
    "@radix-ui/react-tooltip": "1.1.8",
    "canvas-confetti": "1.9.4",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "cmdk": "1.1.1",
    "date-fns": "3.6.0",
    "embla-carousel-react": "8.6.0",
    "input-otp": "1.4.2",
    "lucide-react": "0.487.0",
    "motion": "12.23.24",
    "next-themes": "0.4.6",
    "react-day-picker": "8.10.1",
    "react-dnd": "16.0.1",
    "react-dnd-html5-backend": "16.0.1",
    "react-hook-form": "7.55.0",
    "react-popper": "2.3.0",
    "react-resizable-panels": "2.1.7",
    "react-responsive-masonry": "2.7.1",
    "react-router": "7.13.0",
    "react-slick": "0.31.0",
    "recharts": "2.15.2",
    "sonner": "2.0.3",
    "tailwind-merge": "3.2.0",
    "tw-animate-css": "1.3.8",
    "vaul": "1.1.2"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.1.12",
    "@types/node": "^25.9.3",
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "@vitejs/plugin-react": "4.7.0",
    "tailwindcss": "4.1.12",
    "typescript": "^5.9.3",
    "vite": "6.3.5"
  }
}
